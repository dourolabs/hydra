[metis]
# Namespace the CLI uses when creating Jobs.
namespace = "default"

# Container image the worker Pod will execute.
# TODO: figure out how to tag this properly in kind x_x
worker_image = "sha256:36ac58f5eb66885ea504f908fa3637fc807d35ad1d843e8adec412106eff31a2"

# Optional fallback if the OPENAI_API_KEY environment variable is unset.
OPENAI_API_KEY = ""

[service.repositories]
# Example repository configuration; add additional tables per repository name.
[service.repositories.example]
remote_url = "https://github.com/example/repo.git"
default_branch = "main"
default_image = "metis-worker:latest"
github_token = ""

[background]
# Agent queues automatically enqueue work for assigned issues.
# Add additional [[background.agent_queues]] tables to run multiple queues.
[[background.agent_queues]]
name = "agent-a"
# Prompt provided to the agent; forwarded directly to Codex.
prompt = "You are agent-a working on assigned issues."
# Maximum number of times to spawn a task for the same issue state.
max_tries = 3
# Optional: override the worker image for this queue (falls back to metis.worker_image)
image = "metis-worker:latest"

# Optional environment variables that will be injected into the job alongside
# METIS_ISSUE_ID and METIS_AGENT_NAME.
[background.agent_queues.env_vars]
#EXAMPLE_TOKEN = "secret"

# Optional context bundle (defaults to none)
#[background.agent_queues.context]
#type = "git_repository"
#url = "https://github.com/example/repo.git"
#rev = "main"

[background.scheduler]
# Default backoff settings applied to all background workers unless overridden.
default_initial_backoff_secs = 5
default_max_backoff_secs = 60

[background.scheduler.workers.process_pending_jobs]
# Interval (in seconds) between pending task scans.
interval_secs = 2

[background.scheduler.workers.monitor_running_jobs]
# Interval (in seconds) between running job monitors.
interval_secs = 5

[background.scheduler.workers.run_spawners]
# Interval (in seconds) between spawner executions.
interval_secs = 3

[background.scheduler.workers.poll_github_patches]
# Interval (in seconds) between GitHub patch sync cycles.
interval_secs = 60
#initial_backoff_secs = 5
#max_backoff_secs = 60

[background.github_poller]
# Polling interval (in seconds) used when syncing GitHub PRs for patches.
interval_secs = 60
# Optionally limit the number of patches processed per sync cycle.
#max_patches_per_run = 25

[kubernetes]
# Set to true when the server runs inside a Kubernetes cluster and should use
# its mounted ServiceAccount credentials.
in_cluster = false

# Path to the kubeconfig file with cluster credentials (used when in_cluster = false).
config_path = "~/.kube/config"

# Context within the kubeconfig to select (kubectl config get-contexts).
context = "kind-local-dev"

# Friendly cluster name; purely informational for tooling.
cluster_name = "kind-local-dev"

# Optional explicit API server endpoint; leave blank to use kubeconfig default.
api_server = ""
