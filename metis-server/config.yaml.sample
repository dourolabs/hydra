metis:
  # Namespace the CLI uses when creating Jobs.
  namespace: "default"

  # Required: base64-encoded 32-byte encryption key for user secrets.
  # Generate with: openssl rand -base64 32
  METIS_SECRET_ENCRYPTION_KEY: "REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY"

  # Optional fallback if the OPENAI_API_KEY environment variable is unset.
  OPENAI_API_KEY: ""
  # Optional fallback if the CLAUDE_CODE_OAUTH_TOKEN environment variable is unset.
  CLAUDE_CODE_OAUTH_TOKEN: ""
  # Optional fallback if the ANTHROPIC_API_KEY environment variable is unset.
  ANTHROPIC_API_KEY: ""

  # Optional list of allowed GitHub organizations for logins.
  # Leave empty or omit to allow all organizations.
  allowed_orgs: []

# Storage backend: "sqlite" (default), "postgres", or "memory".
# Each backend carries its own configuration fields.
#
# SQLite (default for single-player mode):
storage_backend: "sqlite"
sqlite_path: "metis.db"
#
# PostgreSQL (for production / multi-player mode):
# storage_backend: "postgres"
# database:
#   url: "postgres://metis:metis@localhost:5432/metis"
#   max_connections: 5
#   min_connections: 1
#   connect_timeout_secs: 5
#   idle_timeout_secs: 300
#
# In-memory (for testing):
# storage_backend: "memory"

# Job engine: "local" (default) or "kubernetes".
# Each backend carries its own configuration fields.
#
# Local Docker (default for single-player mode):
job_engine: "local"
#
# Kubernetes (for production):
# job_engine: "kubernetes"
# kubernetes:
#   in_cluster: false
#   config_path: "~/.kube/config"
#   context: "kind-local-dev"
#   cluster_name: "kind-local-dev"
#   api_server: ""
#   # image_pull_secrets:
#   #   - "ghcr-credentials"

# Authentication mode: "local" or "github".
# - local: auto-creates a default user actor on startup. Requires github_token
#   (a personal access token) for GitHub API access. No GitHub OAuth needed.
# - github: requires the github_app section below for device-flow OAuth.
auth_mode: "local"

# GitHub personal access token — required when auth_mode is "local".
# This token is used by GitHub API consumers (PR sync, patch assets, etc.)
# so they can function without the full GitHub App OAuth flow.
# Required scopes: repo (full control of private repositories).
github_token: "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional username for the local actor (auth_mode: local only).
# Defaults to "local" if omitted, producing actor name "u-local".
# username: "myname"

job:
  # Container image the worker Pod will execute.
  default_image: "metis-worker:latest"
  # Default model to use when job settings omit one.
  default_model: "gpt-4o"
  # CPU limit for worker pods (e.g., "500m", "1", "2.5").
  cpu_limit: "500m"
  # Memory limit for worker pods (e.g., "1Gi", "512Mi", "2G").
  memory_limit: "1Gi"
  # CPU request for worker pods (e.g., "500m", "1", "2.5").
  cpu_request: "500m"
  # Memory request for worker pods (e.g., "1Gi", "512Mi", "2G").
  memory_request: "1Gi"

build_cache:
  # Optional build cache storage configuration for worker runs.
  # Omit this section to disable build caching.
  # include:
  #   - "target/"
  #   - "dist/"
  # exclude:
  #   - "tmp/"
  #   - "*.log"
  # home_include:
  #   - ".cargo/registry/"
  #   - ".cache/pip/"
  # home_exclude:
  #   - ".cache/pnpm/diagnostics/"
  # max_entries_per_repo: 10

  ## Local filesystem storage
  # storage:
  #   type: "filesystem"
  #   root_dir: "/var/lib/metis/build-cache"

  ## S3 storage
  # storage:
  #   type: "s3"
  #   endpoint_url: "https://s3.amazonaws.com"
  #   bucket: "metis-build-cache"
  #   region: "us-east-1"
  #   access_key_id: ""
  #   secret_access_key: ""
  #   session_token: ""

github_app:
  # GitHub App configuration for device flow and API access.
  # Required when auth_mode is "github"; optional (can be omitted) in "local" mode.
  app_id: 1
  # OAuth client_id for device flow (public).
  client_id: "replace-with-client-id"
  # OAuth client_secret for device flow (private).
  client_secret: "replace-with-client-secret"
  # Optional override for GitHub API base URL (used for testing).
  api_base_url: "https://api.github.com"
  # Optional override for GitHub OAuth base URL (used for testing).
  oauth_base_url: "https://github.com"
  # GitHub App private key (PEM format).
  private_key: |
    -----BEGIN RSA PRIVATE KEY-----
    REPLACE_WITH_PRIVATE_KEY
    -----END RSA PRIVATE KEY-----

background:
  github_poller:
    # Polling interval (in seconds) used when syncing GitHub PRs for patches.
    interval_secs: 60

  scheduler:
    process_pending_jobs:
      # Optional scheduler settings for the worker that spawns pending jobs.
      interval_secs: 2
      initial_backoff_secs: 1
      max_backoff_secs: 30
    monitor_running_jobs:
      # Optional scheduler settings for the worker that reconciles running jobs.
      interval_secs: 5
      initial_backoff_secs: 1
      max_backoff_secs: 30
    run_spawners:
      # Optional scheduler settings for the worker that executes spawners.
      interval_secs: 3
      initial_backoff_secs: 1
      max_backoff_secs: 30
    github_poller:
      # Optional scheduler settings for the worker that syncs GitHub patches.
      interval_secs: 60
      initial_backoff_secs: 1
      max_backoff_secs: 30

# ------------------------------------------------------------------
# Policy Engine Configuration
# ------------------------------------------------------------------
# Omit the entire policies section to enable all built-in policies
# with their default parameters (backward-compatible default behavior).
#
# When present, only the policies listed here are active. Policies not
# listed are disabled.
#
# policies:
#
#   ## Restrictions — evaluated before mutations are persisted.
#   restrictions:
#     - "issue_lifecycle_validation"   # Enforce parent/child lifecycle rules (e.g., close children first)
#     - "task_state_machine"           # Enforce valid task status transitions
#     - "duplicate_branch_name"        # Prevent patches with duplicate branch names
#     - "running_job_validation"       # Prevent invalid status transitions on running jobs
#     - "require_creator"              # Require a creator on new issues
#
#   ## Automations — react to persisted events with side effects.
#   ## Order matters: cascade should run before kill_tasks.
#   automations:
#     - "cascade_issue_status"         # Drop children/dependents when an issue enters a terminal state
#     - "kill_tasks_on_issue_failure"  # Kill running tasks when their issue fails/drops
#     - "close_merge_request_issues"   # Close merge-request tracking issues when a patch is merged/closed
#     - "sync_review_request_issues"   # Sync review request issue status with patch review state
#     - "patch_workflow"               # Create MergeRequest/ReviewRequest issues when a patch is created or reopened
#     - "github_pr_sync"              # Sync GitHub PR state with patch status
#     - "notification_generation"      # Generate notifications for relevant events
#     - "inbox_label"                  # Apply inbox label to new issues for inbox functionality
#
#   ## Parameterized automation examples:
#   # automations:
#   #   - name: "cascade_issue_status"
#   #     params:
#   #       trigger_statuses:
#   #         - "dropped"
#   #         - "failed"
#
#   ## patch_workflow with global config:
#   #   - name: "patch_workflow"
#   #     params:
#   #       review_requests:
#   #         - assignee: "reviewer-username"
#   #       merge_request:
#   #         assignee: "$patch_creator"
#   #
#   # Config keys:
#   #   review_requests: list of { assignee } — creates ReviewRequest issues for the patch
#   #   merge_request: { assignee } — creates a MergeRequest issue blocked-on all ReviewRequests
#   #   $patch_creator in assignee strings resolves to the patch creator's username
#   #
#   # Per-repo overrides are managed via the repository's patch_workflow field in the
#   # database (API), not in this static config. DB config takes precedence over
#   # the global config defined here.
#   #
#   # Default (no params): creates a single MergeRequest issue with no assignee.

