{
  "name": "metis-web-root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter @metis/api build && pnpm -r --filter @metis/ui build && pnpm -r --filter @metis/web build",
    "dev": "pnpm -r --filter @metis/web dev",
    "dev:server": "pnpm -r --filter @metis/web dev:server",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "jsdom": "^25.0.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
